      "inputs": {
        "clip_name": "t5xxl_fp16.safetensors",
        "type": "ltxv"
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "cinematic scene motion",
        "clip": [
          "5",
          0
        ]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "static, jitter, flicker, watermark",
        "clip": [
          "5",
          0
        ]
      }
    },
    "10": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "input.png"
      }
    },
    "12": {
      "class_type": "LTXVImgToVideo",
      "inputs": {
        "positive": [
          "6",
          0
        ],
        "negative": [
          "7",
          0
        ],
        "vae": [
          "4",
          2
        ],
        "image": [
          "10",
          0
        ],
        "width": 768,
        "height": 512,
        "length": 97,
        "batch_size": 1
      }
    },
    "20": {
      "class_type": "SamplerCustom",
      "inputs": {
        "model": [
          "4",
          0
        ],
        "add_noise": true,
        "noise_seed": 0,
        "cfg": 3.0,
        "positive": [
          "12",
          0
        ],
        "negative": [
          "12",
          1
        ],
        "sampler": [
          "22",
          0
        ],
        "sigmas": [
          "21",
          0
        ],
        "latent_image": [
          "12",
          2
        ]
      }
    },
    "21": {
      "class_type": "LTXVScheduler",
      "inputs": {
        "steps": 30,
        "max_shift": 2.05,
        "base_shift": 0.95,
        "stretch": true,
        "terminal": 0.1,
        "latent": [
          "12",
          2
        ]
      }
    },
    "22": {
      "class_type": "KSamplerSelect",
      "inputs": {
        "sampler_name": "euler"
      }
    },
    "30": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": [
          "20",
          0
        ],
        "vae": [
          "4",
          2
        ]
      }
    },
    "31": {
      "class_type": "SaveAnimatedWEBP",
      "inputs": {
        "images": [
          "30",
          0
        ],
        "filename_prefix": "comfy_video",
        "fps": 24,
        "lossless": false,
        "quality": 85,
        "method": "default"
      }
    }
  }
}