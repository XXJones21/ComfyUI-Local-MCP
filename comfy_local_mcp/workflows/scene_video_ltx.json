{
  "_meta": {
    "name": "scene_video_ltx",
    "description": "Image-to-video via LTX-Video 0.9.5. Fast default for scene transitions.",
    "required_models": [
      "ltx_video/ltx-video-2b-v0.9.5.safetensors",
      "text_encoders/t5xxl_fp16.safetensors"
    ],
    "required_nodes": [
      "LTXVCheckpointLoader",
      "LTXVConditioning",
      "LTXVImgToVideo",
      "LTXVScheduler",
      "KSamplerSelect",
      "SamplerCustom",
      "VAEDecode",
      "SaveAnimatedWEBP"
    ]
  },
  "_overrides": {
    "prompt": "6.inputs.text",
    "negative_prompt": "7.inputs.text",
    "seed": "20.inputs.seed",
    "image_input": "10.inputs.image",
    "frames": "12.inputs.length",
    "width": "12.inputs.width",
    "height": "12.inputs.height",
    "steps": "21.inputs.steps",
    "ltx_ckpt": "4.inputs.ckpt_name"
  },
  "graph": {
    "4": {
