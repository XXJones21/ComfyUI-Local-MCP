{
  "_meta": {
    "name": "scene_video_ltx2",
    "description": "LTX-2.3 GGUF two-stage text-to-video, portrait 9:16 (768x1344), 121 frames @ 24fps. Verified local on RTX 4080 16GB. Stage1 base model cfg=4 LTXVScheduler (8 steps -- the quality/speed sweet spot: ~2.5min/5s, ~5.2min/10s, vs 20 steps for marginal gain); stage2 distilled-LoRA cfg=1 refine + x2 latent upscale. Override `steps` to tune stage-1.",
    "required_models": [
      "unet/ltx-2.3-22b-dev-Q3_K_S.gguf",
      "text_encoders/gemma-3-12b-it-Q4_K_M.gguf",
      "text_encoders/ltx-2.3-22b-dev_embeddings_connectors.safetensors",
      "vae/ltx-2.3-22b-dev_video_vae.safetensors",
      "vae/ltx-2.3-22b-dev_audio_vae.safetensors",
      "loras/ltx-2.3-22b-distilled-lora-384.safetensors",
      "latent_upscale_models/ltx-2.3-spatial-upscaler-x2-1.0.safetensors"
    ],
    "required_nodes": [
      "UnetLoaderGGUF",
      "DualCLIPLoaderGGUF",
      "VAELoaderKJ",
      "LTXVConditioning",
      "LTXVScheduler",
      "ManualSigmas",
      "CFGGuider",
      "SamplerCustomAdvanced",
      "LTXVLatentUpsampler",
      "LTXVCropGuides",
      "LTXVConcatAVLatent",
      "LTXVSeparateAVLatent",
      "VAEDecodeTiled",
      "CreateVideo",
      "SaveVideo"
    ],
    "notes": "CRITICAL: DualCLIPLoaderGGUF clip_name2 MUST be the embeddings_connectors file (the learned LTX connector), NOT text_projection -- wrong clip2 yields pure noise. clip_name1 is the Gemma GGUF. Source: workflow embedded in unsloth/LTX-2.3-GGUF unsloth_flowers.mp4. Requires the kornia 'pad' shim in ComfyUI-LTXVideo/pyramid_blending.py for the pack to load."
  },
